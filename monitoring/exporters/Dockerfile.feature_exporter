FROM python:3.12-slim

WORKDIR /app

COPY monitoring/exporters/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY monitoring/exporters/postgres_feature_exporter.py /app/postgres_feature_exporter.py

EXPOSE 8001

CMD ["python", "/app/postgres_feature_exporter.py"]
